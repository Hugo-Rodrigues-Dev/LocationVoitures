@page "/catalogue/{Immatriculation}"

@using LocationVoitures.Web.Features.Locations.Components
@using LocationVoitures.Web.Features.Locations.Models
@using LocationVoitures.Web.Features.Locations.Services
@using LocationVoitures.Web.Features.Loueurs.Models
@using LocationVoitures.Web.Features.Loueurs.Services
@using LocationVoitures.Web.Features.Voitures.Models
@using LocationVoitures.Web.Features.Voitures.Services
@using LocationVoitures.Web.Services

@inject VoituresApiClient VoituresApi
@inject LocationsApiClient LocationsApi
@inject LoueursApiClient LoueursApi
@inject UserNotificationService Notifications

<PageTitle>Fiche voiture</PageTitle>

<section class="page-section">
    <p class="mb-3">
        <a href="/catalogue" class="link-secondary">Retour au catalogue</a>
    </p>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-danger" role="alert">@loadError</div>
    }
    else if (isLoading || voiture is null)
    {
        <p><em>Chargement de la fiche voiture...</em></p>
    }
    else
    {
        <div class="page-header">
            <span class="eyebrow">@voiture.Categorie</span>
            <h1>@voiture.Marque @voiture.Modele</h1>
            <p class="lead">
                Immatriculation : <strong>@voiture.Immatriculation</strong> ·
                Prix : <strong>@voiture.PrixParJour.ToString("0.00") EUR / jour</strong>
            </p>
            <p>
                <span class="badge @(voiture.EstDisponible ? "text-bg-success" : "text-bg-secondary")">
                    @(voiture.EstDisponible ? "Disponible aujourd'hui" : "Indisponible aujourd'hui")
                </span>
            </p>
        </div>

        <div class="row g-4">
            <div class="col-12 col-xl-7">
                <section class="panel h-100">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div>
                            <h2 class="mb-1">Historique des locations</h2>
                            <p class="text-muted mb-0">
                                Les locations sont triees par date de debut pour montrer les reservations passees, en cours et futures.
                            </p>
                        </div>
                    </div>

                    <LocationsHistory Locations="locations" />
                </section>
            </div>

            <div class="col-12 col-xl-5">
                <section class="panel h-100">
                    <h2>Reserver cette voiture</h2>
                    <p class="text-muted">
                        La reservation interroge l'API metier puis le service de paiement fictif. En cas de refus, une notification explique la cause.
                    </p>

                    @if (loueurs.Count == 0)
                    {
                        <div class="alert alert-warning mb-0" role="alert">
                            Aucun loueur n'est disponible pour creer une reservation.
                        </div>
                    }
                    else
                    {
                        <ReservationForm Immatriculation="@voiture.Immatriculation"
                                         Loueurs="loueurs"
                                         OnReservationCreated="HandleReservationCreatedAsync" />
                    }
                </section>
            </div>
        </div>
    }
</section>

@code {
    [Parameter]
    public string Immatriculation { get; set; } = string.Empty;

    private VoitureDto? voiture;
    private IReadOnlyList<LocationDto> locations = [];
    private IReadOnlyList<LoueurDto> loueurs = [];
    private string? loadError;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            voiture = await VoituresApi.GetByImmatriculationAsync(Immatriculation);
            locations = await LocationsApi.GetByVoitureAsync(Immatriculation);
            loueurs = await LoueursApi.GetAllAsync();
        }
        catch (Exception ex)
        {
            loadError = "Impossible de charger la fiche de cette voiture.";
            Notifications.ShowException(ex, "Chargement impossible");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleReservationCreatedAsync(ReserverResponse _)
    {
        try
        {
            locations = await LocationsApi.GetByVoitureAsync(Immatriculation);
            voiture = await VoituresApi.GetByImmatriculationAsync(Immatriculation);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Notifications.ShowException(ex, "Rafraichissement impossible");
        }
    }
}

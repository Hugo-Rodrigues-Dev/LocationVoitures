@using LocationVoitures.Web.Features.Voitures.Models

<article class="card h-100 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
                <p class="text-uppercase text-muted small mb-2">@Voiture.Categorie</p>
                <h3 class="h5 mb-1">@Voiture.Marque @Voiture.Modele</h3>
                <p class="mb-2"><strong>Immatriculation :</strong> @Voiture.Immatriculation</p>
            </div>

            <span class="badge @(Voiture.EstDisponible ? "text-bg-success" : "text-bg-secondary")">
                @(Voiture.EstDisponible ? "Disponible" : "Indisponible")
            </span>
        </div>

        <div class="mt-3">
            <p class="mb-0"><strong>Tarif journalier :</strong> @Voiture.PrixParJour.ToString("0.00") EUR</p>
        </div>
    </div>

    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3 d-flex flex-wrap gap-2">
        <a class="btn btn-sm btn-outline-secondary" href="/catalogue/@Voiture.Immatriculation">Voir la fiche</a>
        <a class="btn btn-sm btn-primary" href="/reservations/@Voiture.Immatriculation">Reserver</a>
    </div>
</article>

@code {
    [Parameter]
    public required VoitureDto Voiture { get; set; }
}

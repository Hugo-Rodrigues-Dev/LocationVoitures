@using LocationVoitures.Web.Features.Locations.Models

@if (Locations.Count == 0)
{
    <div class="empty-state">
        <h3>Aucune location enregistree</h3>
        <p>Cette voiture n'a pas encore d'historique de reservation dans l'application.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th scope="col">Periode</th>
                    <th scope="col">Loueur</th>
                    <th scope="col">Statut</th>
                    <th scope="col">Paiement</th>
                    @if (AllowCancellation)
                    {
                        <th scope="col" class="text-end">Action</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var location in Locations.OrderByDescending(item => item.DateDebut))
                {
                    <tr>
                        <td>
                            <strong>@location.DateDebut.ToString("dd/MM/yyyy")</strong>
                            <div class="text-muted small">au @location.DateFin.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td>
                            <strong>@location.LoueurNomComplet</strong>
                            <div class="text-muted small">Loueur #@location.LoueurId</div>
                        </td>
                        <td>
                            <span class="@GetStatusClass(location)">@GetStatusLabel(location)</span>
                        </td>
                        <td>
                            <span class="badge @(location.Paye ? "text-bg-success" : "text-bg-warning")">
                                @(location.Paye ? "Paye" : "En attente")
                            </span>
                        </td>
                        @if (AllowCancellation)
                        {
                            <td class="text-end">
                                @if (CanBeCancelled(location))
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            disabled="@IsCancellationPending(location.Id)"
                                            @onclick="() => CancelAsync(location.Id)">
                                        @(IsCancellationPending(location.Id) ? "Annulation..." : "Annuler")
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">Aucune action</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<LocationDto> Locations { get; set; } = [];

    [Parameter]
    public bool AllowCancellation { get; set; }

    [Parameter]
    public int? PendingCancellationId { get; set; }

    [Parameter]
    public EventCallback<int> OnCancelRequested { get; set; }

    private static string GetStatusLabel(LocationDto location)
    {
        if (location.Annule)
        {
            return "Annulee";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);

        if (location.DateDebut > today)
        {
            return "A venir";
        }

        if (location.DateFin < today)
        {
            return "Terminee";
        }

        return "En cours";
    }

    private static string GetStatusClass(LocationDto location)
    {
        return GetStatusLabel(location) switch
        {
            "Annulee" => "badge text-bg-secondary",
            "A venir" => "badge text-bg-info",
            "Terminee" => "badge text-bg-light",
            _ => "badge text-bg-success"
        };
    }

    private static bool CanBeCancelled(LocationDto location)
    {
        if (location.Annule)
        {
            return false;
        }

        return location.DateFin >= DateOnly.FromDateTime(DateTime.Today);
    }

    private bool IsCancellationPending(int locationId)
        => PendingCancellationId == locationId;

    private async Task CancelAsync(int locationId)
    {
        if (!OnCancelRequested.HasDelegate)
        {
            return;
        }

        await OnCancelRequested.InvokeAsync(locationId);
    }
}

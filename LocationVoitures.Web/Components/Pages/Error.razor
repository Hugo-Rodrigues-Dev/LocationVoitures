@page "/Error"
@using System.Diagnostics

<PageTitle>Erreur</PageTitle>

<section class="page-section">
    <div class="page-header">
        <span class="eyebrow">Erreur</span>
        <h1>Une erreur est survenue pendant le chargement de l'application</h1>
        <p class="lead">
            Le front n'a pas pu terminer correctement la requete en cours. Verifiez que les services Aspire
            sont bien demarres, puis rechargez la page ou revenez a l'accueil.
        </p>
    </div>

    <section class="panel">
        <h2>Que faire maintenant ?</h2>
        <ul class="mb-3">
            <li>Verifier que `LocationVoitures.AppHost` tourne toujours.</li>
            <li>Verifier que `gateway`, `apiservice` et `paymentservice` sont bien en etat `Running` dans Aspire.</li>
            <li>Recharger la page ou revenir a l'accueil.</li>
        </ul>

        @if (ShowRequestId)
        {
            <p class="mb-3">
                <strong>Identifiant de requete :</strong> <code>@requestId</code>
            </p>
        }

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" href="/">Retour a l'accueil</a>
            <a class="btn btn-outline-primary" href="/catalogue">Ouvrir le catalogue</a>
        </div>
    </section>
</section>

@code{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? requestId;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
